<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Edit Event</h1>

  <%= form_with(model: @event, url: event_path(@event), method: :patch, class: "space-y-8") do |f| %>
    <% if @event.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-5">
        <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
          <% @event.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 space-y-5">
      <h2 class="text-lg font-semibold text-gray-900">Event Details</h2>

      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :title, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5" %>
      </div>

      <div>
        <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :location, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5" %>
      </div>
    </div>

    <div class="flex justify-end gap-4 pb-4">
      <%= link_to "Cancel", event_path(@event), class: "px-8 py-3 rounded-lg border border-gray-300 text-gray-700 hover:bg-gray-50 no-underline font-medium" %>
      <%= f.submit "Save Changes", class: "bg-indigo-600 text-white font-semibold px-10 py-3 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
