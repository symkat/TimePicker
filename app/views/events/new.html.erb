<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Create a New Event</h1>

  <%= form_with(model: @event, url: events_path, class: "space-y-8", data: { controller: "event-form" }) do |f| %>
    <% if @event.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-4">
        <h3 class="text-red-800 font-semibold mb-2">Please fix the following:</h3>
        <ul class="list-disc list-inside text-red-700 text-sm">
          <% @event.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Event Details -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 space-y-4">
      <h2 class="text-lg font-semibold text-gray-900">Event Details</h2>

      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "e.g., Team Dinner" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "Optional description..." %>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.text_field :location, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500", placeholder: "e.g., Joe's Pizza" %>
        </div>
        <div>
          <%= f.label :timezone, class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.time_zone_select :timezone, nil, { default: "Eastern Time (US & Canada)" }, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500" %>
        </div>
      </div>
    </div>

    <!-- Time Slots -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" data-controller="time-slots">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">When might this happen?</h2>
      <p class="text-sm text-gray-500 mb-4">Add one or more date/time options for your friends to choose from.</p>

      <div data-time-slots-target="container" class="space-y-3">
        <!-- Initial slot -->
        <div class="flex items-center gap-3 time-slot-row" data-time-slots-target="row">
          <div class="flex-1">
            <input type="datetime-local" name="event[time_slots][][starts_at]"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm" required>
          </div>
          <span class="text-gray-400 text-sm">to</span>
          <div class="flex-1">
            <input type="datetime-local" name="event[time_slots][][ends_at]"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 text-sm">
          </div>
          <button type="button" data-action="time-slots#remove" class="text-red-400 hover:text-red-600 p-1" title="Remove">
            &#10005;
          </button>
        </div>
      </div>

      <button type="button" data-action="time-slots#add"
              class="mt-4 inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-700 font-medium">
        &#43; Add another time option
      </button>
    </div>

    <!-- Questions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" data-controller="questions">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Questions <span class="text-gray-400 font-normal text-sm">(optional)</span></h2>
      <p class="text-sm text-gray-500 mb-4">Ask your friends anything — what to bring, food preferences, etc.</p>

      <div data-questions-target="container" class="space-y-4"></div>

      <button type="button" data-action="questions#add"
              class="mt-4 inline-flex items-center gap-1 text-sm text-indigo-600 hover:text-indigo-700 font-medium">
        &#43; Add a question
      </button>
    </div>

    <!-- Submit -->
    <div class="flex justify-end">
      <%= f.submit "Create Event", class: "bg-indigo-600 text-white font-semibold px-8 py-3 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer" %>
    </div>
  <% end %>
</div>
