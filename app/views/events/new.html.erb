<div class="max-w-4xl mx-auto">
  <h1 class="text-2xl font-bold text-gray-900 mb-8">Create a New Event</h1>

  <%= form_with(model: @event, url: events_path, class: "space-y-8", data: { controller: "event-form timezone" }) do |f| %>
    <% if @event.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-lg p-5">
        <h3 class="text-red-800 font-semibold mb-2">Please fix the following:</h3>
        <ul class="list-disc list-inside text-red-700 text-sm space-y-1">
          <% @event.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <!-- Event Details -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8 space-y-5">
      <h2 class="text-lg font-semibold text-gray-900">Event Details</h2>

      <div>
        <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :title, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5", placeholder: "e.g., Team Dinner" %>
      </div>

      <div>
        <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_area :description, rows: 3, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5", placeholder: "Optional description..." %>
      </div>

      <div>
        <%= f.label :location, class: "block text-sm font-medium text-gray-700 mb-1.5" %>
        <%= f.text_field :location, class: "w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5", placeholder: "e.g., Joe's Pizza" %>
      </div>

      <!-- Hidden timezone field, auto-detected by Stimulus -->
      <%= f.hidden_field :timezone, data: { timezone_target: "field" } %>
    </div>

    <!-- Date & Time Picker -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8" data-controller="date-time-picker">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">When might this happen?</h2>
      <p class="text-sm text-gray-500 mb-6">Click dates on the calendar, then set a time. All dates share the default time unless you customize one.</p>

      <div class="flex flex-col lg:flex-row gap-8">
        <!-- Calendar -->
        <div class="flex-shrink-0">
          <!-- Month navigation -->
          <div class="flex items-center justify-between mb-4">
            <button type="button" data-action="click->date-time-picker#prevMonth"
                    class="p-1.5 rounded-lg hover:bg-gray-100 transition-colors text-gray-600 hover:text-gray-900 cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
              </svg>
            </button>
            <span data-date-time-picker-target="monthLabel" class="text-sm font-semibold text-gray-900"></span>
            <button type="button" data-action="click->date-time-picker#nextMonth"
                    class="p-1.5 rounded-lg hover:bg-gray-100 transition-colors text-gray-600 hover:text-gray-900 cursor-pointer">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </button>
          </div>

          <!-- Day-of-week headers -->
          <div class="grid grid-cols-7 gap-1 mb-1">
            <% %w[Su Mo Tu We Th Fr Sa].each do |day| %>
              <div class="h-8 flex items-center justify-center text-xs font-medium text-gray-500 w-10"><%= day %></div>
            <% end %>
          </div>

          <!-- Calendar grid -->
          <div data-date-time-picker-target="calendar" class="grid grid-cols-7 gap-1"></div>
        </div>

        <!-- Time configuration + selected dates -->
        <div class="flex-1 min-w-0">
          <!-- Default time -->
          <div class="bg-gray-50 rounded-lg p-4 mb-4">
            <h3 class="text-sm font-medium text-gray-700 mb-3">Default Time</h3>
            <div class="flex flex-wrap items-center gap-3">
              <div>
                <label class="block text-xs text-gray-500 mb-1">Starts at</label>
                <div data-time-combobox data-date-time-picker-target="defaultStart" class="relative">
                  <input type="text" value="7:00 PM" data-value="19:00"
                         data-combobox-field="defaultStart"
                         data-action="change->date-time-picker#defaultTimeChanged"
                         autocomplete="off"
                         class="w-28 text-sm rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 py-2 pl-3 pr-2"
                         placeholder="7:00 PM">
                  <div data-combobox-list class="hidden absolute z-50 mt-1 w-36 max-h-48 overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-lg"></div>
                </div>
              </div>

              <div class="flex items-center gap-3">
                <label class="flex items-center gap-2 cursor-pointer">
                  <input type="checkbox" data-date-time-picker-target="endTimeToggle"
                         data-action="change->date-time-picker#toggleEndTime"
                         class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-4 w-4">
                  <span class="text-sm text-gray-600">Add end time</span>
                </label>
              </div>
            </div>

            <div data-date-time-picker-target="endTimeWrapper" class="hidden mt-3">
              <div class="flex items-center gap-3">
                <div>
                  <label class="block text-xs text-gray-500 mb-1">Ends at</label>
                  <div data-time-combobox data-date-time-picker-target="defaultEnd" class="relative">
                    <input type="text" value="9:00 PM" data-value="21:00"
                           data-combobox-field="defaultEnd"
                           data-action="change->date-time-picker#defaultTimeChanged"
                           autocomplete="off"
                           class="w-28 text-sm rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 py-2 pl-3 pr-2"
                           placeholder="9:00 PM">
                    <div data-combobox-list class="hidden absolute z-50 mt-1 w-36 max-h-48 overflow-y-auto bg-white border border-gray-200 rounded-lg shadow-lg"></div>
                  </div>
                </div>
                <div data-date-time-picker-target="overnightBadge" class="hidden mt-4">
                  <span class="inline-flex items-center gap-1 text-xs font-medium text-amber-700 bg-amber-100 px-2.5 py-1 rounded-full">
                    &#9889; ends next day
                  </span>
                </div>
              </div>
              <p class="text-xs text-gray-400 mt-2">If the end time is earlier than the start time, it will be treated as the next day.</p>
            </div>
          </div>

          <!-- Selected dates list -->
          <div>
            <h3 class="text-sm font-medium text-gray-700 mb-3">Selected Dates</h3>
            <div data-date-time-picker-target="selectedList" class="divide-y divide-gray-100">
              <p class="text-sm text-gray-400 italic">Click dates on the calendar to add time options.</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Hidden inputs container -->
      <div data-date-time-picker-target="hiddenInputs"></div>
    </div>

    <!-- Questions -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8" data-controller="questions">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Questions <span class="text-gray-400 font-normal text-sm">(optional)</span></h2>
      <p class="text-sm text-gray-500 mb-6">Ask your friends anything — what to bring, food preferences, etc.</p>

      <div data-questions-target="container" class="space-y-4"></div>

      <button type="button" data-action="questions#add"
              class="mt-2 inline-flex items-center gap-1.5 text-sm text-indigo-600 hover:text-indigo-700 font-semibold px-4 py-2 rounded-lg hover:bg-indigo-50 transition-colors">
        + Add a question
      </button>
    </div>

    <!-- Submit -->
    <div class="flex justify-end pb-4">
      <%= f.submit "Create Event", class: "bg-indigo-600 text-white font-semibold px-10 py-3 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer text-base" %>
    </div>
  <% end %>
</div>
