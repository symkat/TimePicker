<div class="space-y-8">
  <!-- Event Header -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @event.title %></h1>
        <% if @event.description.present? %>
          <p class="text-gray-600 mt-2"><%= @event.description %></p>
        <% end %>
        <div class="flex gap-4 mt-3 text-sm text-gray-500">
          <% if @event.location.present? %>
            <span>&#128205; <%= @event.location %></span>
          <% end %>
          <span>&#127760; <%= @event.timezone %></span>
        </div>
      </div>
      <% if @is_creator %>
        <%= link_to "Edit", edit_event_path(@event), class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium no-underline" %>
      <% end %>
    </div>

    <!-- Share Link -->
    <div class="mt-4 p-3 bg-indigo-50 rounded-lg flex items-center gap-3">
      <span class="text-sm text-indigo-700 font-medium">Share this link:</span>
      <code class="text-sm bg-white px-3 py-1 rounded border border-indigo-200 text-indigo-900 flex-1 select-all"><%= request.base_url %><%= event_path(@event) %></code>
    </div>
  </div>

  <!-- Availability Grid -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Availability</h2>

    <% if @respondents.any? %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="text-left py-2 px-3 bg-gray-50 rounded-tl-lg font-medium text-gray-700 sticky left-0 z-10">Name</th>
              <% @time_slots.each do |slot| %>
                <th class="py-2 px-3 bg-gray-50 text-center font-medium text-gray-700 min-w-[120px]">
                  <div><%= slot.starts_at.in_time_zone(@event.timezone).strftime("%b %-d") %></div>
                  <div class="text-xs text-gray-500 font-normal">
                    <%= slot.starts_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                    <% if slot.ends_at.present? %>
                      - <%= slot.ends_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                    <% end %>
                  </div>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @respondents.each do |respondent| %>
              <tr class="border-t border-gray-100">
                <td class="py-2 px-3 font-medium text-gray-900 sticky left-0 bg-white z-10"><%= respondent.name %></td>
                <% @time_slots.each do |slot| %>
                  <td class="py-2 px-3 text-center">
                    <% if respondent.time_slot_selections.any? { |s| s.event_time_slot_id == slot.id } %>
                      <span class="inline-block w-8 h-8 bg-green-100 text-green-600 rounded-full leading-8 font-bold">&#10003;</span>
                    <% else %>
                      <span class="inline-block w-8 h-8 bg-gray-100 text-gray-300 rounded-full leading-8">&mdash;</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
            <!-- Totals row -->
            <tr class="border-t-2 border-gray-200 bg-gray-50">
              <td class="py-2 px-3 font-semibold text-gray-700 sticky left-0 bg-gray-50 z-10">Total</td>
              <% max_count = @time_slots.map { |s| @respondents.count { |r| r.time_slot_selections.any? { |sel| sel.event_time_slot_id == s.id } } }.max || 0 %>
              <% @time_slots.each do |slot| %>
                <% count = @respondents.count { |r| r.time_slot_selections.any? { |s| s.event_time_slot_id == slot.id } } %>
                <td class="py-2 px-3 text-center font-semibold <%= count == max_count && max_count > 0 ? 'text-green-700 bg-green-50' : 'text-gray-600' %>">
                  <%= count %>/<%= @respondents.size %>
                </td>
              <% end %>
            </tr>
          </tbody>
        </table>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-8">No responses yet. Share the link above to get started!</p>
    <% end %>
  </div>

  <!-- Question Responses -->
  <% if @questions.any? && @respondents.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Poll Responses</h2>

      <% @questions.each do |question| %>
        <div class="mb-6 last:mb-0">
          <h3 class="font-medium text-gray-800 mb-2"><%= question.prompt %></h3>
          <div class="space-y-1">
            <% @respondents.each do |respondent| %>
              <% answer = respondent.answers.find { |a| a.question_id == question.id } %>
              <% if answer&.value.present? %>
                <div class="flex gap-2 text-sm">
                  <span class="font-medium text-gray-700"><%= respondent.name %>:</span>
                  <span class="text-gray-600">
                    <% if question.multiple_choice? %>
                      <% begin %>
                        <%= JSON.parse(answer.value).join(", ") %>
                      <% rescue %>
                        <%= answer.value %>
                      <% end %>
                    <% else %>
                      <%= answer.value %>
                    <% end %>
                  </span>
                </div>
              <% end %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- Response Form -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-6" id="respond">
    <h2 class="text-lg font-semibold text-gray-900 mb-4">Add Your Response</h2>

    <%= form_with(url: event_responses_path(@event), method: :post, class: "space-y-6") do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Your Name</label>
        <input type="text" name="respondent[name]" required
               class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
               placeholder="Enter your name">
      </div>

      <!-- Time Slot Checkboxes -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">When are you available? <span class="text-gray-400">(check all that apply)</span></label>
        <div class="space-y-2">
          <% @time_slots.each do |slot| %>
            <label class="flex items-center gap-3 p-3 rounded-lg border border-gray-200 hover:bg-gray-50 cursor-pointer transition-colors">
              <input type="checkbox" name="respondent[time_slot_ids][]" value="<%= slot.id %>"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-5 w-5">
              <span class="text-sm text-gray-900">
                <strong><%= slot.starts_at.in_time_zone(@event.timezone).strftime("%A, %B %-d") %></strong>
                &middot;
                <%= slot.starts_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                <% if slot.ends_at.present? %>
                  &ndash; <%= slot.ends_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                <% end %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Questions -->
      <% @questions.each do |question| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"><%= question.prompt %></label>
          <% if question.multiple_choice? && question.options.present? %>
            <div class="space-y-2">
              <% question.options.each do |option| %>
                <label class="flex items-center gap-3 p-2 rounded-lg hover:bg-gray-50 cursor-pointer">
                  <input type="checkbox" name="respondent[answers][<%= question.id %>][]" value="<%= option %>"
                         class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
                  <span class="text-sm text-gray-700"><%= option %></span>
                </label>
              <% end %>
            </div>
          <% else %>
            <input type="text" name="respondent[answers][<%= question.id %>]"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500"
                   placeholder="Your answer...">
          <% end %>
        </div>
      <% end %>

      <div>
        <button type="submit" class="bg-indigo-600 text-white font-semibold px-8 py-3 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer">
          Submit Response
        </button>
      </div>
    <% end %>
  </div>
</div>
