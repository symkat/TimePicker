<div class="space-y-8">
  <!-- Event Header -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <div class="flex items-start justify-between">
      <div>
        <h1 class="text-2xl font-bold text-gray-900"><%= @event.title %></h1>
        <% if @event.description.present? %>
          <p class="text-gray-600 mt-3 leading-relaxed"><%= @event.description %></p>
        <% end %>
        <div class="flex flex-wrap gap-4 mt-4 text-sm text-gray-500">
          <% if @event.location.present? %>
            <span>&#128205; <%= @event.location %></span>
          <% end %>
          <% if @event.timezone.present? %>
            <span>&#127760; <%= @event.timezone %></span>
          <% end %>
        </div>
      </div>
      <% if @is_creator %>
        <%= link_to "Edit", edit_event_path(@event), class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium no-underline ml-4" %>
      <% end %>
    </div>

    <!-- Share Link -->
    <div class="mt-6 p-4 bg-indigo-50 rounded-lg flex flex-col sm:flex-row sm:items-center gap-3">
      <span class="text-sm text-indigo-700 font-medium whitespace-nowrap">Share this link:</span>
      <code class="text-sm bg-white px-4 py-2 rounded border border-indigo-200 text-indigo-900 flex-1 select-all break-all"><%= request.base_url %><%= event_path(@event) %></code>
    </div>

    <% if @is_creator %>
      <!-- Creator Link -->
      <div class="mt-3 p-4 bg-amber-50 rounded-lg space-y-2" data-controller="clipboard">
        <div class="flex items-center justify-between">
          <span class="text-sm text-amber-700 font-medium">Your creator link:</span>
          <button type="button"
                  data-action="clipboard#copy"
                  data-clipboard-value-param="<%= request.base_url %><%= claim_event_path(@event, token: @event.creator_token) %>"
                  class="text-sm text-amber-600 hover:text-amber-800 font-medium cursor-pointer">
            Copy
          </button>
        </div>
        <code class="block text-sm bg-white px-4 py-2 rounded border border-amber-200 text-amber-900 select-all break-all"><%= request.base_url %><%= claim_event_path(@event, token: @event.creator_token) %></code>
        <p class="text-xs text-amber-600">Save this link to manage your event from any device or browser.</p>
      </div>
    <% end %>
  </div>

  <!-- Availability Grid -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
    <h2 class="text-lg font-semibold text-gray-900 mb-6">Availability</h2>

    <% if @respondents.any? %>
      <div class="overflow-x-auto -mx-2">
        <table class="w-full text-sm">
          <thead>
            <tr>
              <th class="text-left py-3 px-4 bg-gray-50 rounded-tl-lg font-medium text-gray-700 sticky left-0 z-10">Name</th>
              <% @time_slots.each do |slot| %>
                <th class="py-3 px-4 bg-gray-50 text-center font-medium text-gray-700 min-w-[130px]">
                  <div><%= slot.starts_at.in_time_zone(@event.timezone).strftime("%b %-d") %></div>
                  <div class="text-xs text-gray-500 font-normal mt-0.5">
                    <%= slot.starts_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                    <% if slot.ends_at.present? %>
                      - <%= slot.ends_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                    <% end %>
                  </div>
                </th>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% @respondents.each do |respondent| %>
              <% is_mine = @my_respondent_token == respondent.edit_token %>
              <tr class="border-t border-gray-100 hover:bg-gray-50/50">
                <td class="py-3 px-4 font-medium text-gray-900 sticky left-0 bg-white z-10">
                  <div class="flex items-center gap-2">
                    <span><%= respondent.name %></span>
                    <% if is_mine %>
                      <span class="text-xs text-indigo-500 font-normal">(you)</span>
                    <% end %>
                    <% if is_mine || @is_creator %>
                      <span class="flex gap-1 ml-auto" data-controller="clipboard">
                        <% if is_mine || @is_creator %>
                          <%= link_to "edit", edit_event_response_path(@event, respondent), class: "text-xs text-indigo-500 hover:text-indigo-700 no-underline" %>
                        <% end %>
                        <% if @is_creator %>
                          <button type="button"
                                  data-action="clipboard#copy"
                                  data-clipboard-value-param="<%= request.base_url %><%= edit_event_response_path(@event, respondent) %>"
                                  class="text-xs text-gray-400 hover:text-indigo-600 cursor-pointer"
                                  title="Copy edit link for <%= respondent.name %>">
                            share link
                          </button>
                          <%= button_to "remove", event_response_path(@event, respondent), method: :delete, class: "text-xs text-red-400 hover:text-red-600 cursor-pointer", form: { data: { turbo_confirm: "Remove #{respondent.name}'s response?" } } %>
                        <% end %>
                      </span>
                    <% end %>
                  </div>
                </td>
                <% @time_slots.each do |slot| %>
                  <td class="py-3 px-4 text-center">
                    <% if respondent.time_slot_selections.any? { |s| s.event_time_slot_id == slot.id } %>
                      <span class="inline-flex items-center justify-center w-9 h-9 bg-green-100 text-green-600 rounded-full font-bold text-base">&#10003;</span>
                    <% else %>
                      <span class="inline-flex items-center justify-center w-9 h-9 bg-gray-100 text-gray-300 rounded-full">&mdash;</span>
                    <% end %>
                  </td>
                <% end %>
              </tr>
            <% end %>
            <!-- Totals row -->
            <% max_count = @time_slots.map { |s| @respondents.count { |r| r.time_slot_selections.any? { |sel| sel.event_time_slot_id == s.id } } }.max || 0 %>
            <tr class="border-t-2 border-gray-200">
              <td class="py-3 px-4 font-semibold text-gray-700 sticky left-0 bg-gray-50 z-10">Total</td>
              <% @time_slots.each do |slot| %>
                <% count = @respondents.count { |r| r.time_slot_selections.any? { |s| s.event_time_slot_id == slot.id } } %>
                <td class="py-3 px-4 text-center font-semibold bg-gray-50 <%= count == max_count && max_count > 0 ? 'text-green-700' : 'text-gray-600' %>">
                  <span class="<%= count == max_count && max_count > 0 ? 'bg-green-100 px-3 py-1 rounded-full' : '' %>">
                    <%= count %>/<%= @respondents.size %>
                  </span>
                </td>
              <% end %>
            </tr>
          </tbody>
        </table>
      </div>
    <% else %>
      <div class="text-center py-12">
        <div class="text-4xl mb-3">&#128075;</div>
        <p class="text-gray-500">No responses yet. Share the link above to get started!</p>
      </div>
    <% end %>
  </div>

  <!-- Question Responses -->
  <% if @questions.any? && @respondents.any? %>
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">Poll Responses</h2>

      <div class="space-y-6">
        <% @questions.each do |question| %>
          <div>
            <h3 class="font-medium text-gray-800 mb-3"><%= question.prompt %></h3>
            <div class="space-y-2 pl-4">
              <% @respondents.each do |respondent| %>
                <% answer = respondent.answers.find { |a| a.question_id == question.id } %>
                <% if answer&.value.present? %>
                  <div class="flex gap-3 text-sm py-1">
                    <span class="font-medium text-gray-700 min-w-[80px]"><%= respondent.name %></span>
                    <span class="text-gray-600">
                      <% if question.multiple_choice? %>
                        <% begin %>
                          <%= JSON.parse(answer.value).join(", ") %>
                        <% rescue %>
                          <%= answer.value %>
                        <% end %>
                      <% else %>
                        <%= answer.value %>
                      <% end %>
                    </span>
                  </div>
                <% end %>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- Response Form -->
  <div class="bg-white rounded-xl shadow-sm border border-gray-200 p-8" id="respond">
    <h2 class="text-lg font-semibold text-gray-900 mb-6">Add Your Response</h2>

    <%= form_with(url: event_responses_path(@event), method: :post, class: "space-y-6") do |f| %>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1.5">Your Name</label>
        <input type="text" name="respondent[name]" required
               class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5"
               placeholder="Enter your name">
      </div>

      <!-- Time Slot Checkboxes -->
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-3">When are you available? <span class="text-gray-400">(check all that apply)</span></label>
        <div class="space-y-2">
          <% @time_slots.each do |slot| %>
            <label class="flex items-center gap-4 p-4 rounded-lg border border-gray-200 hover:bg-indigo-50 hover:border-indigo-200 cursor-pointer transition-colors">
              <input type="checkbox" name="respondent[time_slot_ids][]" value="<%= slot.id %>"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-5 w-5">
              <span class="text-sm text-gray-900">
                <strong><%= slot.starts_at.in_time_zone(@event.timezone).strftime("%A, %B %-d") %></strong>
                <span class="text-gray-500">&middot;</span>
                <%= slot.starts_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                <% if slot.ends_at.present? %>
                  &ndash; <%= slot.ends_at.in_time_zone(@event.timezone).strftime("%-I:%M %p") %>
                <% end %>
              </span>
            </label>
          <% end %>
        </div>
      </div>

      <!-- Questions -->
      <% @questions.each do |question| %>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-2"><%= question.prompt %></label>
          <% if question.multiple_choice? && question.options.present? %>
            <div class="space-y-2">
              <% question.options.each do |option| %>
                <label class="flex items-center gap-3 p-3 rounded-lg hover:bg-gray-50 cursor-pointer">
                  <input type="checkbox" name="respondent[answers][<%= question.id %>][]" value="<%= option %>"
                         class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500 h-5 w-5">
                  <span class="text-sm text-gray-700"><%= option %></span>
                </label>
              <% end %>
            </div>
          <% else %>
            <input type="text" name="respondent[answers][<%= question.id %>]"
                   class="w-full rounded-lg border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 px-4 py-2.5"
                   placeholder="Your answer...">
          <% end %>
        </div>
      <% end %>

      <div class="pt-2">
        <button type="submit" class="bg-indigo-600 text-white font-semibold px-10 py-3 rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer text-base">
          Submit Response
        </button>
      </div>
    <% end %>
  </div>
</div>
